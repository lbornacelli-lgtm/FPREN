[Unit]
Description=FPREN Comprehensive 2PM Report Generator
After=network.target mongod.service

[Service]
Type=oneshot
User=ufuser
WorkingDirectory=/home/ufuser/Fpren-main
ExecStart=/usr/bin/Rscript /home/ufuser/Fpren-main/reports/generate_comprehensive_2pm.R
Environment=MONGO_URI=mongodb://localhost:27017/
StandardOutput=journal
StandardError=journal
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
